---
import { getCollection, type CollectionEntry } from "astro:content";

import Layout from "../../layouts/Layout.astro";
import Article from "../../components/page/Article.astro";
import BackButtonHeader from "../../layouts/BackButtonHeader.astro";

export const prerender = true;

type PathParams = { lang: string; slug: string };
type PathProps = {
  post: CollectionEntry<"landingpage">;
};

export async function getStaticPaths() {
  const posts = await getCollection("landingpage");

  const paths: { params: PathParams; props: PathProps }[] = [];

  for (const post of posts) {
    const parts = post.id.split("/");

    if (parts.length === 3 && parts[1] === "documents") {
      const [lang, folderName, fileName] = parts;
      const fileNameNoExt = fileName.replace(/\.md$/, "");
      const slugParts = fileNameNoExt.split("_");
      const slug = slugParts.slice(1).join("-");

      paths.push({
        params: { lang, slug },
        props: {
          post,
        },
      });
    }
  }

  return paths;
}

const { lang } = Astro.params;
const { post } = Astro.props as PathProps;
---

<Layout title={post.data.title} description={post.data.description}>
  <BackButtonHeader href={`/${lang}`} />
  <Article post={post} />
</Layout>
