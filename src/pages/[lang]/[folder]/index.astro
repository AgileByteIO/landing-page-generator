---
import { getCollection, type CollectionEntry, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Feed from "../../../components/page/Feed.astro";
import TagBatch from "../../../components/ui/TagBatch.astro";
import IconButton from "../../../components/action/IconButton.astro";

export const prerender = true;

type PathParams = { lang: string; folder: string };
type FeedProps = { title: string; folder: string; type: 'feed'; items: { title: string; description?: string; href: string }[] };
type ArticleData = { title: string; folder: string; type: 'article'; post: CollectionEntry<'landingpage'> };
type PathProps = FeedProps | ArticleData;

export async function getStaticPaths() {
  const posts = await getCollection("landingpage");

  const filteredPosts = posts.filter((p: CollectionEntry<"landingpage">) => {
    const parts = p.id.split("/");
    return parts.length === 4 && parts[1] === "root";
  });

  const folderGroups = new Map<string, CollectionEntry<"landingpage">[]>();
  filteredPosts.forEach((post) => {
    const parts = post.id.split("/");
    const folderKey = `${parts[0]}/${parts[1]}/${parts[2]}`;
    const existing = folderGroups.get(folderKey);
    if (existing) {
      existing.push(post);
    } else {
      folderGroups.set(folderKey, [post]);
    }
  });

  const paths: { params: PathParams; props: PathProps }[] = [];

  for (const [folderKey, folderPosts] of folderGroups) {
    const lang = folderKey.split("/")[0];
    let folderSlug: string;
    let folderTitle: string;

    {
      const folderParts = folderKey.split("/")[2].split("_");
      folderSlug = folderParts.slice(1, -1).join("-");
      folderTitle = folderParts.slice(1, -1).join(" ").replace(/([A-Z])/g, " $1").trim();
      folderTitle = folderTitle.charAt(0).toUpperCase() + folderTitle.slice(1);
    }

    if (folderPosts.length === 1) {
      const post = folderPosts[0];
      paths.push({
        params: { lang, folder: folderSlug },
        props: { title: post.data.title || folderTitle, folder: folderSlug, type: 'article', post },
      });
    } else {
      const items = folderPosts.map((post) => {
        const idParts = post.id.split("/");
        const fileNameWithPrefix = idParts[3]?.replace(/\.md$/, "") || "";
        const itemSlug = fileNameWithPrefix.replace(/^\d+_/, "");
        return {
          title: post.data.title,
          description: post.data.description,
          href: `/${lang}/${folderSlug}/${itemSlug}`,
        };
      });

      paths.push({
        params: { lang, folder: folderSlug },
        props: { title: folderTitle, folder: folderSlug, type: 'feed', items },
      });
    }
  }

  return paths;
}

const { lang, folder } = Astro.params as PathParams;
const props = Astro.props as PathProps;

let Content: any;
if (props.type === 'article') {
  const articleProps = props as ArticleData;
  const rendered = await render(articleProps.post);
  Content = rendered.Content;
}
---

<Layout title={props.title} description="">
  <div class="x-header">
    <div class="x-header-gradient"></div>
    <div class="x-header-content">
      <IconButton icon="arrow-left" style="outline" href={`/${lang}`} type="link" />
    </div>
  </div>

  {props.type === 'feed' && <Feed title={props.title} items={(props as FeedProps).items} />}

  {props.type === 'article' && Content && (
    <article class="article">
      <header class="article-head">
        <h1 class="article-title">{(props as ArticleData).post.data.title}</h1>
        {(props as ArticleData).post.data.tags && (props as ArticleData).post.data.tags.length > 0 && (
          <div class="article-tags">
            <TagBatch tagIds={(props as ArticleData).post.data.tags} />
          </div>
        )}
        {(props as ArticleData).post.data.description && (
          <p class="article-summary">{(props as ArticleData).post.data.description}</p>
        )}
      </header>
      <div class="article-content">
        <Content />
      </div>
    </article>
  )}
</Layout>

<style>
  .x-header {
    position: relative;
    min-height: 20vh;
    display: flex;
    align-items: flex-end;
    margin-bottom: 2rem;
  }

  .x-header-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, var(--background) 0%, transparent 40%),
      linear-gradient(225deg, var(--primary) 0%, transparent 50%),
      linear-gradient(45deg, var(--accent) 0%, transparent 40%);
    background-color: var(--background);
    opacity: 0.85;
  }

  .x-header-content {
    position: relative;
    bottom: -1rem;
    left: 1.25rem;
  }

  .x-header-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--secondary);
  }

  .article {
    width: 100%;
    max-width: 85rem;
    margin: 0 auto;
  }

  .article-head {
    margin-bottom: 2rem;
    padding: 0 2rem;
  }

  .article-content {
    padding: 0 2rem;
  }

  .article-title {
    background: linear-gradient(
      135deg,
      var(--secondary) 0%,
      var(--primary) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }

  .article-tags {
    margin-bottom: 1rem;
  }

  .article-summary {
    font-size: 1.125rem;
    line-height: 1.6;
    opacity: 0.85;
    max-width: 65ch;
  }

  .article-content :global(p) {
    margin-bottom: 1rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1rem;
    padding: 0 0 0 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(a) {
    color: var(--primary);
    text-decoration: underline;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    opacity: 0.8;
  }

  .article-content :global(code) {
    background: var(--foreground);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .article-content :global(pre) {
    background: var(--primary);
    color: var(--background);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .article-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  @media (max-width: 640px) {
    .x-header {
      min-height: 15vh;
    }
    .x-header-content {
      padding: 0.25rem 0.125rem;
    }
    .x-header-title {
      font-size: 1.5rem;
    }
    .article-head,
    .article-content {
      padding: 0 1rem;
    }
    .article {
      margin: 0;
    }
  }
</style>