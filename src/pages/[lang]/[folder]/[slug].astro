---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Article from "../../../components/page/Article.astro";
import BackButtonHeader from "../../../layouts/BackButtonHeader.astro";

export const prerender = true;

type PathParams = { lang: string; folder: string; slug: string };
type PathProps = { post: CollectionEntry<"landingpage">; backUrl: string };

export async function getStaticPaths() {
  const posts = await getCollection("landingpage");

  const filteredPosts = posts.filter((p: CollectionEntry<"landingpage">) => {
    const parts = p.id.split("/");
    return parts.length === 4 && parts[1] === "root";
  });

  const folderGroups = new Map<string, CollectionEntry<"landingpage">[]>();
  filteredPosts.forEach((post) => {
    const parts = post.id.split("/");
    const folderKey = `${parts[0]}/${parts[1]}/${parts[2]}`;
    const existing = folderGroups.get(folderKey);
    if (existing) {
      existing.push(post);
    } else {
      folderGroups.set(folderKey, [post]);
    }
  });

  const paths: { params: PathParams; props: PathProps }[] = [];

  for (const [folderKey, folderPosts] of folderGroups) {
    // Skip single article folders
    if (folderPosts.length <= 1) continue;

    const lang = folderKey.split("/")[0];
    let folderSlug: string;

    {
      const folderParts = folderKey.split("/")[2].split("_");
      folderSlug = folderParts.slice(1, -1).join("-");
    }

    for (const post of folderPosts) {
      const idParts = post.id.split("/");
      const fileNameWithPrefix = idParts[3]?.replace(/\.md$/, "") || "";
      const itemSlug = fileNameWithPrefix.replace(/^\d+_/, "");

      paths.push({
        params: { lang, folder: folderSlug, slug: itemSlug },
        props: {
          post,
          backUrl: `/${lang}/${folderSlug}`,
        },
      });
    }
  }

  return paths;
}

const { post, backUrl } = Astro.props as PathProps;
---

<Layout title={post.data.title} description={post.data.description}>
  <BackButtonHeader href={backUrl} />
  <Article post={post} />
</Layout>