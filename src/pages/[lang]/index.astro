---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SectionSwitcher from '../../components/section/SectionSwitcher.astro';

export const prerender = true;

export async function getStaticPaths() {
  const supportedLanguages = ['en', 'de'];
  
  return supportedLanguages.map(lang => ({
    params: { lang },
    props: { lang },
  }));
}

interface Props {
  lang: string;
}

const { lang } = Astro.props;

const allContent = await getCollection('landingpage');
const langContent = allContent.filter(post => post.id.startsWith(`${lang}/root/`));

const mainSubfolders = [...new Set(
  langContent.map(post => {
    return `${post.id.split('/')[2]}`;
  })
)];

interface SectionData {
  folder: string;
  order: number;
  component: 'hero' | 'carousel' | 'grid';
  title: string;
}

const sections: SectionData[] = mainSubfolders.map(folder => {
  console.info('folder %s', folder);
  const folderWithoutLang = folder.split('/')[1] || folder;
  const folderParts = folderWithoutLang.split('_');
  const order = parseInt(folderParts[0], 10);
  const title = folderParts[1].replace('-', ' ').trim(); 
  const component =  folderParts[2] as 'hero' | 'carousel' | 'grid'; 
 
  
  return {
    folder,
    order,
    component,
    title,
  };
});

sections.sort((a, b) => a.order - b.order);
---

<Layout title="AgileByte OÜ" description="">
  <SectionSwitcher lang={lang} sections={sections} />
</Layout>
