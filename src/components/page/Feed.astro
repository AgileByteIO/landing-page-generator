---
interface FeedItem {
  title: string;
  description?: string;
  href: string;
}

interface Props {
  title?: string;
  items: FeedItem[];
}

const { title, items } = Astro.props;
---

<section>
  <div class="section-content">
    {title && <h1>{title}</h1>}
    <div class="feed-list">
      {items.map((item) => (
        <a href={item.href} class="feed-card">
          <h2 class="feed-title">{item.title}</h2>
          {item.description && <p class="feed-description">{item.description}</p>}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .feed-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feed-card {
    display: block;
    padding: 1.5rem;
    background: var(--background);
    border: var(--border-width) solid var(--card-border);
    border-radius: var(--border-radius);
    text-decoration: none;
    color: inherit;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .feed-card:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--hover-shadow);
  }

  .feed-title {
    margin: 0 0 0.5rem 0;
    color: var(--primary);
  }

  .feed-description {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .feed-card {
      padding: 1.25rem;
    }
  }

  @media (max-width: 1366px) {
    .feed-section {
      margin: 0;
    }
  }
</style>