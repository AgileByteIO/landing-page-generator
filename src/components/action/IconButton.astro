---
import FeatherIcon from '../ui/FeatherIcon.astro';

interface Props {
  icon: string;
  id?: string;
  iconSize?: number;
  style?: 'default' | 'outline' | 'ghost';
  type?: 'button' | 'link';
  href?: string;
  onClick?: string;
  class?: string;
  ariaLabel?: string;
}

const {
  icon,
  id,
  iconSize = 20,
  style = 'default',
  type = 'button',
  href = '#',
  onClick,
  class: className,
  ariaLabel,
} = Astro.props;

const borderWidth = import.meta.env.BORDER_WIDTH || '2px';
---

{type === 'link' ? (
  <a
    href={href}
    id={id}
    target={href.startsWith('http://') || href.startsWith('https://') ? (new URL(href).hostname !== Astro.site?.hostname ? '_blank' : undefined) : undefined}
    rel={href.startsWith('http://') || href.startsWith('https://') ? (new URL(href).hostname !== Astro.site?.hostname ? 'noopener noreferrer' : undefined) : undefined}
    class:list={['icon-btn', `icon-btn-${style}`, className]}
    aria-label={ariaLabel}
  >
    <FeatherIcon name={icon} size={iconSize} />
  </a>
) : (
  <button
    id={id}
    type="button"
    onclick={onClick}
    class:list={['icon-btn', `icon-btn-${style}`, className]}
    aria-label={ariaLabel}
  >
    <FeatherIcon name={icon} size={iconSize} />
  </button>
)}

<style define:vars={{ borderWidth }}>
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border-radius: 50%;
    border: var(--border-width) solid var(--primary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .icon-btn-default {
    background-color: var(--primary);
    color: var(--background);
    border-color: var(--primary);
  }

  .icon-btn-default:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .icon-btn-outline {
    background-color: var(--background);
    color: var(--primary);
    border-color: var(--primary);
  }

  .icon-btn-outline:hover {
    background-color: var(--primary);
    color: var(--background);
  }

  .icon-btn-ghost {
    background-color: transparent;
    color: var(--primary);
    border-color: transparent;
  }

  .icon-btn-ghost:hover {
    background-color: rgba(var(--primary-rgb, 37, 99, 235), 0.1);
  }
</style>