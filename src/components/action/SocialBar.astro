---
import SocialMediaIcon from '../ui/SocialMediaIcon.astro';
import IconButton from './IconButton.astro';

interface Props {
  socials: Record<string, string>;
  class?: string;
  color?: string;
  hoverColor?: string;
  iconSize?: number;
}

const { socials, class: className, color, hoverColor, iconSize = 24 } = Astro.props;
---

<div 
  class:list={['social-bar', className]}
  style={`--social-color: ${color || 'currentColor'}; --social-hover-color: ${hoverColor || 'var(--primary)'}; --social-bg: ${color ? 'transparent' : 'var(--secondary)'};`}
>
  {Object.entries(socials).map(([icon, url]) => (
    <a 
      href={url}
      class="social-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={icon}
    >
      <IconButton 
        type="link" 
        href={url}
        style="ghost-current"
        ariaLabel={icon}
      >
        <SocialMediaIcon name={icon} size={iconSize} />
      </IconButton>
    </a>
  ))}
</div>

<style>
  .social-bar {
    display: inline-flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.75rem 1rem;
    background-color: var(--social-bg);
    border-radius: 2rem;
  }

  .social-link {
    color: var(--social-color);
    transition: color 0.2s ease;
  }

  .social-link:hover {
    color: var(--social-hover-color);
  }

  .social-link :global(.icon-btn) {
    border-color: transparent;
    background: transparent;
    color: inherit;
  }

  .social-link:hover :global(.icon-btn) {
    border-color: transparent;
    background: transparent;
    color: inherit;
    opacity: 0.8;
    transform: translateY(-2px);
  }
</style>