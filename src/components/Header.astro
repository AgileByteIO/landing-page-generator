---
// Header.astro - Sticky header with glass blur effect and animation
import { getCollection } from 'astro:content';
import LangSwitcher from '../components/action/LangSwitcher';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Landingpage",
  description = "A minimalistic landing page"
} = Astro.props;

const primaryColor = import.meta.env.PRIMARY_COLOR || "#2563eb";
const secondaryColor = import.meta.env.SECONDARY_COLOR || "#1e293b";
const accentColor = import.meta.env.ACCENT_COLOR || "#f59e0b";
const backgroundColor = import.meta.env.BACKGROUND_COLOR || "#f8fafc";

const supportedLanguages = ['en', 'de'];
const currentPath = Astro.url.pathname;
const langMatch = currentPath.match(/^\/([a-z]{2})(\/|$)/);
const currentLang = langMatch ? langMatch[1] : 'en'; // Default to 'en' if no language detected

const allContent = await getCollection('landingpage');
const documents = allContent
  .filter(post => post.id.startsWith(`${currentLang}/documents/`))
  .map(post => {
    const parts = post.id.split('/');
    const fileName = parts[2].replace(/\.md$/, '');
    const folderName = parts[1];
    return {
      title: post.data.title,
      href: `/${parts[0]}/${folderName}/${fileName}`
    };
  });
---
<header class="header">
  <div class="header-container">
    <a href="/" class="logo">Logo</a>
    <nav class="nav">
      {currentLang && (
        <LangSwitcher 
          client:load 
          supportedLanguages={supportedLanguages} 
        />
      )}
      {documents.length > 0 && (
        <ul class="nav-links">
          {documents.map(doc => (
            <li key={doc.href}>
              <a href={doc.href}>{doc.title}</a>
            </li>
          ))}
        </ul>
      )}
    </nav>
  </div>
</header>

<style>
  /* Header with glass blur effect and animation */
  .header {
    position: sticky;
    top: 0;
    z-index: 1000;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    background-color: rgba(255, 255, 255, 0.8);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    animation: slideDown 0.6s ease-out;
  }
  
  @keyframes slideDown {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .nav-links {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }
  
  .nav-links a {
    color: var(--secondary);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
    position: relative;
    padding: 0.25rem 0;
  }
  
  .nav-links a:hover {
    color: var(--primary);
  }
  
  .nav-links a.active {
    color: var(--primary);
    font-weight: 600;
  }
  
  .nav-links a.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--primary);
  }
  
  /* Responsive adjustments */
  @media (max-width: 640px) {
    .header-container {
      flex-direction: column;
      align-items: stretch;
    }
    
    .nav {
      width: 100%;
      justify-content: center;
    }
    
    .nav-links {
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }
  }
</style>