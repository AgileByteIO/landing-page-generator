---
// Hero.astro - Simplified hero component without shader logic
// Uses global styling from CSS variables
// Configurable alignment: left, center, right
// Background options: gradient or image
// Limited configuration set for simplicity

interface Props {
  title: string;
  description?: string;
  author?: string;
  href: string;
  // Layout: stacked (vertical) or side-by-side (horizontal)
  layout?: 'stacked' | 'side-by-side';
  // Text alignment: left, center, or right
  alignment?: 'left' | 'center' | 'right';
  // CTA button variant
  ctaVariant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  // Whether to show author line
  showAuthor?: boolean;
  // Max lines for description before truncation
  descriptionMaxLines?: number;
  // Height behavior: full-screen, fixed, or auto
  height?: 'full-screen' | 'fixed' | 'auto';
  // Fixed height in pixels when height='fixed'
  minHeight?: number;
  // Background type: gradient or image (shader removed)
  backgroundType?: 'gradient' | 'image';
  // Gradient color stops (CSS gradient format) when backgroundType='gradient'
  gradientColors?: string[];
  // Image URL when backgroundType='image'
  imageSrc?: string;
  // Shape dividers: top and bottom
  shapeDividerTop?: boolean | 'wave' | 'curve' | 'angle';
  shapeDividerBottom?: boolean | 'wave' | 'curve' | 'angle';
  // Social proof badge
  socialProof?: { label: string; count: number };
}

// Default values
const {
  title,
  description,
  author,
  href,
  layout = 'stacked',
  alignment = 'left',
  ctaVariant = 'primary',
  showAuthor = true,
  descriptionMaxLines = 3,
  height = 'full-screen',
  minHeight = 600,
  backgroundType = 'gradient',
  gradientColors = ['var(--primary)', 'var(--secondary)'],
  imageSrc,
  shapeDividerTop = false,
  shapeDividerBottom = false,
  socialProof
} = Astro.props;

// Helper function to get CTA class based on variant
function getCtaClass(variant: string): string {
  const base = 'hero-link';
  switch (variant) {
    case 'primary': return `${base} hero-link-primary`;
    case 'secondary': return `${base} hero-link-secondary`;
    case 'outline': return `${base} hero-link-outline`;
    case 'ghost': return `${base} hero-link-ghost`;
    default: return base;
  }
}

// Helper function to get background class
function getBackgroundClass(): string {
  switch (backgroundType) {
    case 'gradient':
      return 'hero-bg-gradient';
    case 'image':
      return imageSrc ? 'hero-bg-image' : 'hero-bg-solid';
    default:
      return 'hero-bg-solid';
  }
}

// Helper function to get height class
function getHeightClass(): string {
  switch (height) {
    case 'full-screen':
      return 'hero-height-full';
    case 'fixed':
      return 'hero-height-fixed';
    case 'auto':
      return 'hero-height-auto';
    default:
      return 'hero-height-auto';
  }
}

// Helper function to get text alignment class
function getTextAlignClass(): string {
  switch (alignment) {
    case 'left': return 'hero-text-left';
    case 'center': return 'hero-text-center';
    case 'right': return 'hero-text-right';
    default: return 'hero-text-left';
  }
}

// Helper function to get layout class
function getLayoutClass(): string {
  return layout === 'side-by-side' 
    ? 'hero-layout-side-by-side'
    : 'hero-layout-stacked';
}
---
<!-- Hero Section -->
<section 
  class={`hero ${getHeightClass()} ${getBackgroundClass()}`}
>
  {/* Optional shape dividers would go here if needed */}
  
  <div 
    class="hero-content"
    define:vars={{
      '--layout-direction': layout === 'side-by-side' ? 'row' : 'column',
      '--layout-gap': '2rem',
      '--description-margin-bottom': showAuthor && author ? '1.5rem' : '2rem',
      '--description-max-lines': descriptionMaxLines
    }}
  >
    {/* Content column */}
    <div class="hero-text-column">
      {socialProof && (
        <div class="hero-social-proof">
          <span>{socialProof.label}</span>
          <span>{socialProof.count.toLocaleString()}</span>
        </div>
      )}
      
      <h1 
        class="hero-title"
      >
        {title}
      </h1>
      
      {description && (
        <p 
          class="hero-description"
        >
          {description}
        </p>
      )}
      
      {showAuthor && author && (
        <p class="hero-author">
          By {author}
        </p>
      )}
      
      <a 
        href={href}
        class={getCtaClass(ctaVariant)}
      >
        Read more
      </a>
    </div>
    
    {/* Image column for side-by-side layout */}
    {layout === 'side-by-side' && imageSrc && (
      <div 
        class="hero-image-column"
      >
        <img 
          src={imageSrc} 
          alt={`${title} illustration`}
          class="hero-image"
        />
      </div>
    )}
  </div>
</section>

<style>
  /* Global hero styles - these use CSS variables from global.css */
  .hero-link {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary);
    color: var(--background);
    text-decoration: none;
    border-radius: 6px;
    border: 2px solid var(--primary);
    font-weight: 500;
    transition: all 0.2s ease;
  }
  
  .hero-link:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }
  
  .hero-link-primary {
    background-color: var(--primary);
    color: var(--background);
    border-color: var(--primary);
  }
  
  .hero-link-primary:hover {
    background-color: var(--background);
    color: var(--primary);
  }
  
  .hero-link-secondary {
    background-color: var(--secondary);
    color: var(--background);
    border-color: var(--secondary);
  }
  
  .hero-link-secondary:hover {
    background-color: var(--background);
    color: var(--secondary);
  }
  
  .hero-link-outline {
    background-color: transparent;
    color: var(--primary);
    border: 2px solid var(--primary);
  }
  
  .hero-link-outline:hover {
    background-color: var(--primary);
    color: var(--background);
  }
  
  .hero-link-ghost {
    background-color: transparent;
    color: var(--primary);
    border: 1px solid var(--primary);
  }
  
  .hero-link-ghost:hover {
    background-color: var(--primary);
    color: var(--background);
    border-color: transparent;
  }
  
  .hero-social-proof {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--secondary);
    margin-bottom: 1rem;
  }
  
  .hero-title {
    margin-bottom: 1rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--primary);
  }
  
  .hero-description {
    margin-bottom: var(--description-margin-bottom, 2rem);
    line-height: 1.6;
    color: var(--secondary);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: var(--description-max-lines, 3);
  }
  
  .hero-author {
    font-size: 0.875rem;
    font-style: italic;
    color: var(--accent);
    margin-bottom: 2rem;
  }
  
  .hero-text-column {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .hero-image-column {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .hero-image {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    box-shadow: var(--box-shadow, 0 4px 6px rgba(0,0,0,0.1));
  }
  
  /* Layout variations */
  .hero-layout-stacked {
    flex-direction: column;
  }
  
  .hero-layout-side-by-side {
    flex-direction: row;
    align-items: center;
  }
  
  /* Gap utility */
  .hero-content {
    display: flex;
    gap: var(--layout-gap, 2rem);
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    position: relative;
    z-index: 3;
    color: var(--text-primary);
  }
  
  /* Responsive adjustments */
  @media (min-width: 640px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }
  
  @media (min-width: 768px) {
    .hero-title {
      font-size: 3rem;
    }
    
    .hero-description {
      font-size: 1.25rem;
    }
  }
  
  @media (max-width: 640px) {
    .hero-content {
      padding: 1.5rem;
      flex-direction: column !important;
      gap: 2rem !important;
      text-align: center;
    }
    
    .hero-title {
      font-size: 2rem;
    }
    
    .hero-description {
      font-size: 1rem;
    }
  }
</style>