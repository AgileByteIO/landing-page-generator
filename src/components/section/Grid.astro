---
import FeatherIcon from '../ui/FeatherIcon.astro';
import ServiceIcon from '../ui/ServiceIcon';

interface GridItem {
  title: string;
  description?: string;
  href: string;
  'service-icon'?: string;
}

interface Props {
  id?: string;
  title?: string;
  items: GridItem[];
  background?: string;
}

const { id, title, items, background = '' } = Astro.props;
---

<section id={id} class:list={['grid-section', background.split(' ')]}>
  <div class="section-content">
    {title && <h2>{title}</h2>}
    <div class="grid-container">
      {items.map((item) => (
        <a href={item.href} class="grid-card">
          <div class="card-inner">
            {item['service-icon'] && (
              <div class="card-icon">
                <ServiceIcon name={item['service-icon']} size={32} />
              </div>
            )}
            <h3>{item.title}</h3>
            {item.description && <p class="card-description">{item.description}</p>}
            <span class="card-arrow">
              <FeatherIcon name="arrow-right" size="20" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .grid-card {
    display: block;
    background: white;
    border-radius: var(--border-radius);
    border: var(--border-width) solid var(--card-border);
    box-shadow: var(--card-shadow);
    text-decoration: none;
    color: inherit;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    position: relative;
  }

  .grid-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .grid-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--hover-shadow);
    border-color: var(--primary);
  }

  .grid-card:hover::before {
    transform: scaleX(1);
  }

  .card-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
  }

  .card-icon {
    margin-bottom: 1rem;
    color: var(--primary);
  }

  .card-title {
    margin-bottom: 0.75rem;
  }

  .card-description {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: auto;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    color: var(--primary);
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .grid-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 640px) {
    .grid-container {
      grid-template-columns: 1fr;
    }

    .card-inner {
      padding: 1.25rem;
    }
  }
</style>