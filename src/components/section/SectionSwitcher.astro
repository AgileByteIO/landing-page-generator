---
import Section from './Section.astro';

interface SectionData {
  folder: string;
  order: number;
  component: 'hero' | 'carousel' | 'grid';
  title: string;
}

interface Props {
  lang: string;
  sections: SectionData[];
}

const { lang, sections } = Astro.props;
---

{sections.map((section, index) => (
  <Section 
    lang={lang} 
    path={`${lang}/${section.folder}/`} 
    component={section.component}
    showTitle={index > 0 ? section.title : undefined}
  />
))}
