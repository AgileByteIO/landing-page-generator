---
import Button from '../action/Button.astro';

interface Props {
  id?: string;
  title: string;
  description?: string;
  author?: string;
  link?: string;
  size?: 'sm' | 'md' | 'lg' | 'full';
  background?: string;
}

const { id, title, description, author, link, size = 'full', background = '' } = Astro.props;

const sizeClasses = {
  sm: 'hero-sm',
  md: 'hero-md',
  lg: 'hero-lg',
  full: 'hero-full'
};

const isExternal = link?.startsWith('http');
const isMailto = link?.startsWith('mailto');
const iconName = isMailto ? 'mail' : 'arrow-right';
---

<section id={id} class:list={['hero', sizeClasses[size], background.split(' ')]}>
  <div class="hero-gradient"></div>
  <div class="hero-glow"></div>
  <div class="section-content">
    <div class="hero-content">
      <h1 class="hero-title">{title}</h1>
      {description && (
        <p class="hero-description">
          <span class="hero-description-text">{description}</span>
        </p>
      )}
      {link && (
        <div class="hero-button">
          <Button 
            type="link" 
            href={link} 
            label="Read more" 
            icon={iconName} 
            iconPosition="right"
            style="accent"
            size="md"
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener noreferrer' : undefined}
          />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .hero-sm { min-height: 12.5rem; }
  .hero-md { min-height: 18.75rem; }
  .hero-lg { min-height: 25rem; }
  .hero-full { min-height: 31.25rem; }

  .section-content {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 85rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    margin-top: clamp(2rem, 5vw, 4rem);
    z-index: 1;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, var(--background) 0%, transparent 40%),
      linear-gradient(225deg, var(--primary) 0%, transparent 50%),
      linear-gradient(45deg, var(--accent) 0%, transparent 40%);
    background-color: var(--background);
    opacity: 0.85;
    z-index: 0;
  }
  .hero-glow {
    position: absolute;
    width: 200%;
    height: 200%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at center, var(--primary) 0%, transparent 70%);
    opacity: 0.12;
    filter: blur(3.75rem);
    animation: pulse 8s ease-in-out infinite;
    z-index: 0;
    pointer-events: none;
  }

  @keyframes pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.12; }
    50% { transform: translate(-50%, -50%) scale(1.15); opacity: 0.18; }
  }

  .hero-content {
    width: 100%;
    max-width: 50rem;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--primary);
  }

  .hero-description {
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    line-height: 1.65;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: fadeIn 0.8s ease-out 0.2s forwards;
  }

  .hero-description-text {
    display: inline-block;
    color: rgba(var(--foreground-rgb, 100, 116, 139), 0.85);
    filter: blur(0.3px);
    transition: filter 0.3s ease;
  }

  .hero:hover .hero-description-text {
    filter: blur(0);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-author {
    font-style: italic;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeIn 0.8s ease-out 0.4s forwards;
  }

  .hero-button {
    opacity: 0;
    animation: fadeIn 0.8s ease-out 0.6s forwards;
  }

  @media (max-width: 40rem) {
    .hero-content {
      margin-top: clamp(1.5rem, 4vw, 2.5rem);
    }
    .hero-sm { min-height: 10rem; }
    .hero-md { min-height: 14rem; }
    .hero-lg { min-height: 18rem; }
    .hero-full { min-height: 22rem; }
    .hero-link { font-size: 0.875rem; }
    .hero-link svg { width: 0.875rem; height: 0.875rem; }
  }
</style>