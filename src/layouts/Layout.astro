---
import { loadEnv } from '../lib/loadEnv';
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import LangSwitcher from '../components/action/LangSwitcher';
import CookieConsent from '../components/action/CookieConsent';
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Landingpage",
  description = "A minimalistic landing page"
} = Astro.props;

const { theme, company } = loadEnv();

const currentPath = Astro.url.pathname;
const langMatch = currentPath.match(/^\/([a-z]{2})(\/|$)/);
const currentLang = langMatch ? langMatch[1] : null;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
];

const cookieConsents = await getCollection('landingpage');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <Header logo={company.brandName} navItems={navItems} showLangSwitcher={!!currentLang}>
      <LangSwitcher client:load supportedLanguages={['en', 'de']} slot="lang-switcher" />
    </Header>

    <main>
      <slot />
    </main>

    <CookieConsent client:load cookies={cookieConsents} />

    <Footer companyName={company.companyName} legalAddress={company.companyLegalAddress} vatNo={company.companyVatNo} />
  </body>
</html>

<style define:vars={{ 
  primaryColor: theme.primaryColor, 
  secondaryColor: theme.secondaryColor, 
  accentColor: theme.accentColor, 
  backgroundColor: theme.backgroundColor, 
  borderWidth: theme.borderWidth, 
  borderRadius: theme.borderRadius, 
  boxShadow: theme.boxShadow 
}}>
  :root {
    --primary: var(--primaryColor);
    --secondary: var(--secondaryColor);
    --accent: var(--accentColor);
    --background: var(--backgroundColor);
    --border-width: var(--borderWidth);
    --border-radius: var(--borderRadius);
    --box-shadow: var(--boxShadow);
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    width: 100%;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>