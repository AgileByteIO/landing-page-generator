---
import { getCollection } from 'astro:content';
import { tWithLang } from '../lib/i18n';

interface DocItem {
  title: string;
  href: string;
}

interface Props {
  companyName?: string;
  legalAddress?: string;
  vatNo?: string;
}

const { companyName = 'Company Name', legalAddress = '', vatNo = '' } = Astro.props;

const currentPath = Astro.url.pathname;
const langMatch = currentPath.match(/^\/([a-z]{2})(\/|$)/);
const lang = langMatch ? langMatch[1] : 'en';

const vatPrefix = tWithLang(lang, 'footer.vat_prefix');
const cookiePolicyText = tWithLang(lang, 'footer.cookie_policy');
const currentYear = new Date().getFullYear();
const copyrightText = tWithLang(lang, 'dynamic.copyright', currentYear, companyName);

const allContent = await getCollection('landingpage');

const documents: DocItem[] = allContent
  .filter(post => post.id.startsWith(`${lang}/documents/`))
  .map(post => {
    const parts = post.id.split('/');
    const fileNameWithPrefix = parts[parts.length - 1].replace(/\.md$/, '');
    const slugParts = fileNameWithPrefix.split("_");
    const slug = slugParts.slice(1).join("-");
    return {
      title: post.data.title,
      href: `/${lang}/${slug}`
    };
  });
---

<footer class="footer">
  <div class="footer-container">
{documents.length > 0 && (
      <nav class="footer-nav">
        {documents.map(doc => (
          <a href={doc.href} class="footer-link">{doc.title}</a>
        ))}
        <button id="cookie-policy-btn" class="footer-link-btn">{cookiePolicyText}</button>
      </nav>
    )}
    <p class="footer-copyright">&copy; {copyrightText}</p>
    {legalAddress && <p class="footer-legal">{legalAddress}</p>}
    {vatNo && <p class="footer-vat">{vatPrefix} {vatNo}</p>}
  </div>
</footer>

<script>
  document.getElementById('cookie-policy-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.dispatchEvent(new CustomEvent('open-cookie-modal'));
  });
</script>

<style>
  .footer {
    background-color: var(--secondary);
    color: white;
    padding: 2rem 1.5rem;
    margin-top: auto;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-link, .footer-link-btn {
    color: white;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s ease;
    background: none;
    border: none;
    font: inherit;
    cursor: pointer;
  }

  .footer-link:hover, .footer-link-btn:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .footer-copyright {
    opacity: 0.7;
    font-size: 0.875rem;
  }

  .footer-legal, .footer-vat {
    opacity: 0.6;
    font-size: 0.75rem;
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .footer-nav {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>