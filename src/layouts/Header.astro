---
import IconButton from "../components/action/IconButton.astro";
import LangSwitcher from "../components/action/LangSwitcher";
import FeatherIcon from "../components/ui/FeatherIcon.astro";
import LogoIcon from "../components/ui/LogoIcon.astro";

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  logo?: string;
  logoHref?: string;
  navItems?: NavItem[];
  showLangSwitcher?: boolean;
  supportedLanguages?: string[];
}

const {
  logo = "Logo",
  logoHref = "/",
  navItems = [],
  supportedLanguages = ["en", "de"],
} = Astro.props;
---

<header class="header" id="main-header">
  <div class="header-container">
    <a href={logoHref} class="header-logo"><LogoIcon size={24} /><span class="logo-text">{logo}</span></a>
    <div class="header-hamburger">
      <IconButton
        id="menu-toggle"
        icon="menu"
        style="ghost"
        type="button"
      />
    </div>
    <nav class="header-nav" id="main-nav">
      <ul class="header-nav-list">
        {
          navItems.map((item) => (
            <li class="header-nav-item">
              <a href={item.href} class="header-nav-link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="header-actions">
        <LangSwitcher client:load supportedLanguages={supportedLanguages} />
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById("main-header");
  const menuToggle = document.getElementById("menu-toggle");
  const mainNav = document.getElementById("main-nav");

  const handleScroll = () => {
    if (window.scrollY > 20) {
      header?.classList.add("is-scrolled");
    } else {
      header?.classList.remove("is-scrolled");
    }
  };

  window.addEventListener("scroll", handleScroll);
  handleScroll();

  menuToggle?.addEventListener("click", () => {
    mainNav?.classList.toggle("is-open");
    menuToggle.classList.toggle("is-open");
  });

  document.addEventListener("click", (e) => {
    if (
      mainNav?.classList.contains("is-open") &&
      !mainNav.contains(e.target as Node) &&
      !menuToggle?.contains(e.target as Node)
    ) {
      mainNav.classList.remove("is-open");
      menuToggle?.classList.remove("is-open");
    }
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    transition: all 0.5s ease;
    border: 0;
  }

  .header.is-scrolled {
    background: var(--background);
  }

  .header-container {
    max-width: 85rem;
    margin: 0 auto;
    padding: 0.5rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .header-logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--primary);
    text-decoration: none;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.75rem;
    border-radius: var(--border-radius);
    font-family: var(--header-font), system-ui, sans-serif;
    color: var(--secondary);
  }

  .header-logo:hover {
    opacity: 0.8;
  }

  .logo-text {
    display: inline-block;
    letter-spacing: 0.1rem;
    font-size: 2rem;
  }

  .header-hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header-nav-list {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    align-items: center;
  }

  .header-nav-link {
    color: var(--secondary);
    text-transform: capitalize;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    padding: 0.5rem 0;
    position: relative;
    transition: color 0.2s ease;
  }

  .header-nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary);
    transition: width 0.2s ease;
  }

  .header-nav-link:hover {
    color: var(--primary);
  }

  .header-nav-link:hover::after {
    width: 100%;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .header-hamburger {
      display: flex;
    }

    .header-logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .header-nav {
      position: fixed;
      top: 60px;
      left: 0;
      bottom: 0;
      width: 280px;
      background: var(--background);
      flex-direction: column;
      align-items: flex-start;
      padding: 1rem 1.5rem 2rem;
      gap: 1rem;
      border-right: 1px solid var(--background);
      box-shadow: 4px 0 12px var(--foreground);
      transform: translateX(-100%);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }

    .header-nav.is-open {
      transform: translateX(0);
      opacity: 1;
      visibility: visible;
    }

    .header-nav-list {
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-start;
      width: 100%;
    }

    .header-nav-link {
      display: block;
      padding: 0.75rem 0;
      font-size: 1rem;
    }

    .header-actions {
      justify-content: flex-start;
      padding-top: 0.5rem;
      width: 100%;
    }
  }
</style>
